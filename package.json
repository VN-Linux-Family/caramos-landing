{
  "name": "caramos-landing",
  "version": "1.0.1",
  "private": true,
  "type": "module",
  "description": "Bilingual Vite + React landing page for CaramOS.",
  "scripts": {
    "sync:installer": "node scripts/sync-installer.mjs",
    "dev": "yarn sync:installer && vite --host 0.0.0.0",
    "start": "yarn sync:installer && vite --host 0.0.0.0",
    "build": "yarn sync:installer && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "deploy": "yarn build && npx wrangler pages deploy dist --project-name caramos-landing"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "vite": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {},
  "keywords": [
    "CaramOS",
    "Linux",
    "Vietnam",
    "React",
    "Vite",
    "Cloudflare Pages"
  ],
  "license": "GPL-3.0"
}